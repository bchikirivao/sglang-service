# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# NATS
NATS_URL=nats://localhost:4222
QUEUE_GROUP=sglang-service
HEALTH_SUBJECT=infer.health

# HuggingFace token
# SGLang uses huggingface_hub which reads HF_TOKEN directly from the environment.
HF_TOKEN=your_token_here

# Model
MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# SGLang Engine options
#
# DTYPE: "auto" = BF16 on Ampere+, recommended
DTYPE=auto
#
# QUANTIZATION: SGLang requires pre-quantized models — it cannot quantize
# at load time like mistralrs ISQ. Leave empty for full BF16 baseline.
#
# Options (must match the model weights format):
#   fp8        - works with standard BF16 model, ~2x speedup on Ampere+
#   awq        - use with a pre-quantized AWQ model (4-bit, closest to Q4K)
#   awq_marlin - AWQ with Marlin kernels, faster on Ampere
#   gptq       - use with a pre-quantized GPTQ model
#
# For apples-to-apples with mistralrs Q4K:
#   MODEL_ID=hugging-quants/Meta-Llama-3.2-3B-Instruct-AWQ-INT4
#   QUANTIZATION=awq
QUANTIZATION=
#
# MEM_FRACTION_STATIC: fraction of GPU memory for KV cache (default 0.88)
MEM_FRACTION_STATIC=0.88
#
# MAX_TOTAL_TOKENS: 0 = auto (SGLang calculates from available VRAM)
MAX_TOTAL_TOKENS=0
#
# DISABLE_RADIX_CACHE: set true to benchmark without prefix caching
DISABLE_RADIX_CACHE=false

# Request TTL
MAX_REQUEST_AGE_MS=5000

# Inference defaults
DEFAULT_MAX_TOKENS=256
DEFAULT_TEMPERATURE=0.0
